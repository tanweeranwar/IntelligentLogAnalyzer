@page "/analyze"
@using LogAnalyzer.Application.Interfaces
@using LogAnalyzer.Domain.Models
@inject ILogParser LogParser
@rendermode InteractiveServer

<PageTitle>Analyze Logs</PageTitle>

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1>Intelligent Log Analyzer</h1>

        <p class="text-muted">
            Upload an application log to detect and aggregate
            production-support incidents.
        </p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <label class="form-label fw-semibold">
                Select log file
            </label>

            <InputFile OnChange="HandleFileSelected"
                       accept=".txt,.log"
                       disabled="@isProcessing"
                       class="form-control" />

            <div class="form-text">
                Supported formats: .txt and .log.
                Maximum size: 10 MB.
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (isProcessing)
    {
        <div class="alert alert-info">
            <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm"
                     role="status">
                </div>

                <span>Analyzing log file...</span>
            </div>
        </div>
    }

    @if (result is not null)
    {
        <SummaryCards Result="@result" />

        <IncidentList Incidents="@result.Incidents" />
    }
</div>

@code {
    private const long MaximumFileSize =
        10 * 1024 * 1024;

    private bool isProcessing;
    private string? errorMessage;
    private LogAnalysisResult? result;

    private async Task HandleFileSelected(
        InputFileChangeEventArgs args)
    {
        result = null;
        errorMessage = null;
        isProcessing = true;

        try
        {
            var file = args.File;

            var allowedExtensions = new[]
            {
                ".txt",
                ".log"
            };

            var extension =
                Path.GetExtension(file.Name);

            if (!allowedExtensions.Contains(
                    extension,
                    StringComparer.OrdinalIgnoreCase))
            {
                errorMessage =
                    "Only .txt and .log files are supported.";

                return;
            }

            await using var stream =
                file.OpenReadStream(MaximumFileSize);

            result =
                await LogParser.AnalyzeAsync(stream);
        }
        catch (IOException)
        {
            errorMessage =
                "The file is too large or could not be read.";
        }
        catch (OperationCanceledException)
        {
            errorMessage =
                "The log analysis operation was cancelled.";
        }
        catch (Exception ex)
        {
            errorMessage =
                $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }
}
@page "/analyze"
@using LogAnalyzer.Application.Interfaces
@using LogAnalyzer.Domain.Models
@inject ILogParserResolver ParserResolver
@rendermode InteractiveServer

<PageTitle>Analyze Logs</PageTitle>

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1>Intelligent Log Analyzer</h1>

        <p class="text-muted">
            Upload an application log to detect and aggregate
            production-support incidents.
        </p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <label class="form-label fw-semibold">
                Select log file
            </label>

            <InputFile OnChange="HandleFileSelected"
                       accept="@AcceptedFileTypes"
                       disabled="@isProcessing"
                       class="form-control" />

            <div class="form-text">
                Supported formats:
                @SupportedFormatsText.
                Maximum size: 10 MB.
            </div>

            @if (!string.IsNullOrWhiteSpace(selectedParserName))
            {
                <div class="alert alert-info mt-3 mb-0 py-2">
                    Parser selected:
                    <strong>@selectedParserName</strong>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (isProcessing)
    {
        <div class="alert alert-info">
            <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm"
                     role="status">
                </div>

                <span>Analyzing log file...</span>
            </div>
        </div>
    }

    @if (result is not null)
    {
        <HealthDashboard Health="@result.Health" />

        <SummaryCards Result="@result" />

        <IncidentList Incidents="@result.Incidents" />
    }
</div>

@code {
    private const long MaximumFileSize =
        10 * 1024 * 1024;

    private bool isProcessing;
    private string? errorMessage;
    private string? selectedParserName;
    private LogAnalysisResult? result;

    private string AcceptedFileTypes =>
        string.Join(
            ",",
            ParserResolver.SupportedExtensions);

    private string SupportedFormatsText =>
        string.Join(
            ", ",
            ParserResolver.SupportedExtensions
                .Select(extension =>
                    extension.ToUpperInvariant()));

    private async Task HandleFileSelected(
        InputFileChangeEventArgs args)
    {
        result = null;
        errorMessage = null;
        selectedParserName = null;
        isProcessing = true;

        try
        {
            var file = args.File;

            await using var uploadStream =
                file.OpenReadStream(MaximumFileSize);

            await using var seekableStream =
                new MemoryStream();

            await uploadStream.CopyToAsync(
                seekableStream);

            seekableStream.Position = 0;

            var parser =
                await ParserResolver.ResolveAsync(
                    file.Name,
                    seekableStream);

            selectedParserName =
                parser.Name;

            seekableStream.Position = 0;

            result =
                await parser.AnalyzeAsync(
                    seekableStream);
        }
        catch (NotSupportedException ex)
        {
            errorMessage =
                ex.Message;
        }
        catch (IOException)
        {
            errorMessage =
                "The file is too large or could not be read.";
        }
        catch (OperationCanceledException)
        {
            errorMessage =
                "The log analysis operation was cancelled.";
        }
        catch (Exception ex)
        {
            errorMessage =
                $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }
}
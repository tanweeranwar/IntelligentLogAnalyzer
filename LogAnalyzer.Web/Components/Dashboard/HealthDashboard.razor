@using LogAnalyzer.Domain.Models

<div class="card shadow-sm mb-4 health-card">
    <div class="card-body">
        <div class="row g-4 align-items-center">
            <div class="col-lg-3">
                <div class="text-muted small">
                    Production health
                </div>

                <div class="d-flex align-items-center gap-3 mt-2">
                    <div class="@GetHealthScoreClass(Health.Status)">
                        @Health.HealthScore%
                    </div>

                    <div>
                        <div class="fs-4 fw-semibold">
                            @Health.Status
                        </div>

                        <div class="small text-muted">
                            Based on detected incident priority
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-6 col-md">
                        <div class="health-metric">
                            <div class="small text-muted">
                                Incidents
                            </div>

                            <div class="fs-4 fw-semibold">
                                @Health.ActiveIncidents
                            </div>
                        </div>
                    </div>

                    <div class="col-6 col-md">
                        <div class="health-metric">
                            <div class="small text-muted">
                                Critical
                            </div>

                            <div class="fs-4 fw-semibold text-danger">
                                @Health.CriticalIncidents
                            </div>
                        </div>
                    </div>

                    <div class="col-6 col-md">
                        <div class="health-metric">
                            <div class="small text-muted">
                                High
                            </div>

                            <div class="fs-4 fw-semibold text-warning">
                                @Health.HighIncidents
                            </div>
                        </div>
                    </div>

                    <div class="col-6 col-md">
                        <div class="health-metric">
                            <div class="small text-muted">
                                Medium
                            </div>

                            <div class="fs-4 fw-semibold text-primary">
                                @Health.MediumIncidents
                            </div>
                        </div>
                    </div>

                    <div class="col-6 col-md">
                        <div class="health-metric">
                            <div class="small text-muted">
                                Low
                            </div>

                            <div class="fs-4 fw-semibold text-secondary">
                                @Health.LowIncidents
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-muted">
                            Most impacted server
                        </div>

                        <div class="fw-semibold text-break">
                            @FormatValue(Health.MostImpactedServer)
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">
                            Most impacted API
                        </div>

                        <div class="fw-semibold text-break">
                            @FormatValue(Health.MostImpactedApi)
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">
                            Most common exception
                        </div>

                        <div class="fw-semibold text-break">
                            @FormatValue(Health.MostCommonException)
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">
                            Average incident duration
                        </div>

                        <div class="fw-semibold">
                            @FormatDuration(
                                                        Health.AverageIncidentDuration)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ApplicationHealth Health { get; set; } = new();

    private static string GetHealthScoreClass(
        string status)
    {
        return status switch
        {
            "Healthy" =>
                "health-score bg-success-subtle text-success",

            "Degraded" =>
                "health-score bg-warning-subtle text-warning-emphasis",

            "Poor" =>
                "health-score bg-warning text-dark",

            "Critical" =>
                "health-score bg-danger text-white",

            _ =>
                "health-score bg-secondary-subtle text-secondary"
        };
    }

    private static string FormatValue(
        string? value)
    {
        return string.IsNullOrWhiteSpace(value) ||
               value == "-"
            ? "Not detected"
            : value;
    }

    private static string FormatDuration(
        TimeSpan duration)
    {
        if (duration == TimeSpan.Zero)
        {
            return "Not detected";
        }

        if (duration.TotalHours >= 1)
        {
            return $"{duration.TotalHours:F1} hours";
        }

        if (duration.TotalMinutes >= 1)
        {
            return $"{duration.TotalMinutes:F1} minutes";
        }

        return $"{duration.TotalSeconds:F1} seconds";
    }
}